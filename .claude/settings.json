{
  "_comment": "Settings for sessions on the BestPractice repo itself (instantiated from templates/harness/claude-code/settings.json; paths adapted because the tools live at tools/, not process/upstream/tools/).",
  "permissions": {
    "allow": [
      "Bash(grep *)",
      "Bash(git fetch *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push -u origin *)",
      "Bash(git check-ignore *)",
      "Bash(git check-attr *)",
      "Bash(python3 tools/doc_lint.py *)",
      "Bash(python3 tools/practice_audit.py)",
      "Bash(python3 tools/practice_audit.py *)",
      "Bash(python3 deck/build_deck.py *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
